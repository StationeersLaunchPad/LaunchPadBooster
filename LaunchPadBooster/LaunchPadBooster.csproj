<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>LaunchPadBooster</AssemblyName>
    <RootNamespace>$(AssemblyName)</RootNamespace>

    <ParentDir>$(MSBuildThisFileDirectory)../</ParentDir>
  </PropertyGroup>
  
  <Target Name="CopyOutput" AfterTargets="Build">
    <Copy SourceFiles="$(OutputPath)\$(AssemblyName).dll" DestinationFiles="$(SLPPluginPath)\$(AssemblyName).dll" />
  </Target>

  <Import Project="$(ParentDir)LPB.common.props" />
</Project>